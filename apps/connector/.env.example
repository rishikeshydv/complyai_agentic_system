APP_NAME=Comply AI Connector
APP_ENV=production
LOG_LEVEL=INFO

# Aurora PostgreSQL (required)
CONNECTOR_DB_URL=postgresql+psycopg2://<db_user>:<db_password>@<aurora-writer-endpoint>:5432/connector?sslmode=require

# Connector auth (required)
CONNECTOR_API_KEY=<shared-connector-api-key>
REQUIRE_SIGNED_REQUESTS=true
SIGNED_REQUEST_SECRET=<shared-signing-secret>

# Core callback + allowlist (required)
CORE_ALERT_CALLBACK_URL=http://core-api:8000
FIELD_ALLOWLIST_PATH=apps/connector/connector/allowlist.yaml

# Startup guards (optional)
DB_WAIT_TIMEOUT_SECONDS=120
DB_WAIT_INTERVAL_SECONDS=2

# Reserved for future connector-side cache/search integrations (optional)
REDIS_URL=rediss://:<redis_auth_token>@<redis-endpoint>:6379/0
ELASTICSEARCH_URL=https://<opensearch-endpoint>
ELASTICSEARCH_USERNAME=<opensearch-username>
ELASTICSEARCH_PASSWORD=<opensearch-password>
