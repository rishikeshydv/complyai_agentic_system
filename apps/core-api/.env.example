APP_NAME=Comply AI Core Platform
APP_ENV=production
LOG_LEVEL=INFO

# Aurora PostgreSQL (required)
CORE_DB_URL=postgresql+psycopg2://<db_user>:<db_password>@<aurora-writer-endpoint>:5432/core?sslmode=require

# Redis / ElastiCache (required for Celery + ingestion scheduler)
REDIS_URL=rediss://<REDIS_USERNAME>:<REDIS_PASSWORD>@<REDIS_HOST>:<REDIS_PORT>/<REDIS_DB>
REDIS_HOST=<REDIS_HOST>
REDIS_PORT=<REDIS_PORT>
REDIS_DB=<REDIS_DB>
REDIS_USERNAME=<REDIS_USERNAME>
REDIS_PASSWORD=<REDIS_PASSWORD>

# JWT (required)
JWT_SECRET=<strong-random-secret>
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=120

# Connector routing/auth (required)
CONNECTOR_BASE_URL=http://connector:8100
CONNECTOR_BANK_URLS={"demo":"http://connector:8100"}
CONNECTOR_API_KEY=<shared-connector-api-key>
CONNECTOR_REQUIRE_SIGNED=true
CONNECTOR_SIGNED_SECRET=<shared-signing-secret>

# LLM/prompt metadata (required)
LLM_PROVIDER=mock
LLM_MODEL_NAME=mock-llm-v1
PROMPT_VERSION=v1
CASEFILE_SCHEMA_VERSION=1.0

# Web origin(s) allowed by core-api (required)
CORS_ALLOW_ORIGINS=https://<web-domain>

# Worker/beat behavior (required)
CELERY_TASK_ALWAYS_EAGER=false
AUTO_INGEST_ENABLED=true
AUTO_INGEST_INTERVAL_SECONDS=30
AUTO_INGEST_BATCH_SIZE=100
AUTO_INGEST_OVERLAP_SECONDS=30

# Startup guards (optional)
DB_WAIT_TIMEOUT_SECONDS=120
DB_WAIT_INTERVAL_SECONDS=2

# OpenSearch / Elasticsearch (optional, reserved for search integration)
ELASTICSEARCH_URL=https://<opensearch-endpoint>
ELASTICSEARCH_USERNAME=<opensearch-username>
ELASTICSEARCH_PASSWORD=<opensearch-password>

# Law Search V2 (exact module integration)
LAWS_V2_DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@<aurora-writer-endpoint>:5432/core?sslmode=require
LAWS_V2_USE_ES=true
LAWS_V2_ENABLE_LLM=false
LAWS_V2_ES_URL=https://<elasticsearch-endpoint>
LAWS_V2_ES_API_KEY=<elasticsearch-api-key>
LAWS_V2_ES_CHUNKS_INDEX=reg_chunks
LAWS_V2_ES_OBLIGATIONS_INDEX=reg_obligations
LAWS_V2_CHUNK_MIN_CHARS=500
LAWS_V2_CHUNK_MAX_CHARS=1500
LAWS_V2_OBLIGATION_GENERATOR_VERSION=mock-obligation-extractor-v1
LAWS_V2_CURATED_SEED_IF_EMPTY=false
LAWS_V2_ENABLE_BACKFILL=false
LAWS_V2_BACKFILL_LIMIT=0
LAWS_V2_ENABLE_MAPPING_SEED=false

# Optional Aurora-style split vars for laws DB (auto-builds LAWS_V2_DATABASE_URL if unset)
AURORA_DB_NAME=complyaiv1
AURORA_DB_USER=postgres
AURORA_DB_PASSWORD=<aurora-password>
AURORA_ENDPOINT=<aurora-endpoint>
AURORA_PORT=5432

# Optional Elastic Cloud alias vars (used if LAWS_V2_ES_* unset)
ES_ENDPOINT=https://<elasticsearch-endpoint>
ES_API_KEY=<elasticsearch-api-key>
ES_INDEX=regulatory_documents_prod

# Optional AWS credentials (for S3/export integrations)
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
AWS_REGION=us-east-1
S3_BUCKET=<s3-bucket-name>
