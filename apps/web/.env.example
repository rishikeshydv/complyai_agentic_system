# Public runtime config only.
# Do NOT place DB/Redis/OpenSearch credentials in web env files.
NEXT_PUBLIC_CORE_API_URL=https://<core-api-domain>
BACKEND_API_URL=http://<core-api-host>:8000
CORE_API_INTERNAL_URL=http://core-api:8000

# Optional if you add a backend proxy endpoint for search.
NEXT_PUBLIC_SEARCH_API_URL=https://<core-api-domain>/v1/search
