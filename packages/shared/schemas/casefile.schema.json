{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comply-ai.local/schemas/casefile.schema.json",
  "title": "CaseFile",
  "type": "object",
  "required": [
    "schema_version",
    "prompt_version",
    "model_provider",
    "model_name",
    "evidence_hash",
    "header",
    "executive_summary",
    "trigger_explanation",
    "rule_evaluation_table",
    "customer_context",
    "transaction_evidence",
    "regulatory_traceability",
    "timeline_and_audit",
    "sar_draft",
    "export_bundle"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "prompt_version": { "type": "string" },
    "model_provider": { "type": "string" },
    "model_name": { "type": "string" },
    "evidence_hash": { "type": "string" },
    "header": {
      "type": "object",
      "required": ["alert_id", "alert_type", "status", "created_at"],
      "properties": {
        "alert_id": { "type": "string" },
        "alert_type": { "type": "string", "enum": ["AML", "SANCTIONS"] },
        "status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "customer_id": { "type": ["string", "null"] },
        "transaction_id": { "type": ["string", "null"] },
        "source_system": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "executive_summary": {
      "type": "object",
      "required": ["bullets", "recommended_disposition", "confidence", "evidence_pointers"],
      "properties": {
        "bullets": { "type": "array", "items": { "type": "string" } },
        "recommended_disposition": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_pointers": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "trigger_explanation": {
      "type": "object",
      "required": ["observed_facts", "interpretation", "evidence_pointers"],
      "properties": {
        "observed_facts": { "type": "string" },
        "interpretation": { "type": "string" },
        "evidence_pointers": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "rule_evaluation_table": {
      "type": "object",
      "required": ["rows"],
      "properties": {
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "operator", "threshold", "actual", "window_days", "satisfied", "evidence_pointer"],
            "properties": {
              "field": { "type": "string" },
              "operator": { "type": "string" },
              "threshold": {},
              "actual": {},
              "window_days": { "type": ["integer", "null"] },
              "satisfied": { "type": "boolean" },
              "evidence_pointer": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "customer_context": {
      "type": "object",
      "required": ["summary", "key_facts"],
      "properties": {
        "summary": { "type": "string" },
        "key_facts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value", "evidence_pointer"],
            "properties": {
              "label": { "type": "string" },
              "value": {},
              "evidence_pointer": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "transaction_evidence": {
      "type": "object",
      "required": ["summary", "key_transactions", "aggregates"],
      "properties": {
        "summary": { "type": "string" },
        "key_transactions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["transaction_id", "description", "evidence_pointer"],
            "properties": {
              "transaction_id": { "type": "string" },
              "description": { "type": "string" },
              "evidence_pointer": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "aggregates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value", "evidence_pointer"],
            "properties": {
              "label": { "type": "string" },
              "value": {},
              "evidence_pointer": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "regulatory_traceability": {
      "type": "object",
      "required": ["citations"],
      "properties": {
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["citation_id", "title", "jurisdiction", "why_relevant", "evidence_pointers"],
            "properties": {
              "citation_id": { "type": "string" },
              "title": { "type": "string" },
              "jurisdiction": { "type": "string" },
              "text_snippet": { "type": ["string", "null"] },
              "why_relevant": { "type": "string" },
              "evidence_pointers": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "timeline_and_audit": {
      "type": "object",
      "required": ["events"],
      "properties": {
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["action", "actor_type", "actor_id", "timestamp", "notes"],
            "properties": {
              "action": { "type": "string" },
              "actor_type": { "type": "string" },
              "actor_id": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "notes": { "type": "string" },
              "metadata": { "type": "object" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "sar_draft": {
      "type": "object",
      "required": ["required", "narrative_draft", "fields", "evidence_pointers"],
      "properties": {
        "required": { "type": "boolean" },
        "narrative_draft": { "type": "string" },
        "fields": { "type": "object" },
        "evidence_pointers": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "export_bundle": {
      "type": "object",
      "required": ["version", "generated_at", "export_id", "source_payload_hash", "evidence_hash", "casefile_hash"],
      "properties": {
        "version": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "export_id": { "type": "string" },
        "source_payload_hash": { "type": "string" },
        "evidence_hash": { "type": "string" },
        "casefile_hash": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
