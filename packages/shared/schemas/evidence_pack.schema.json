{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comply-ai.local/schemas/evidence_graph.schema.json",
  "title": "EvidenceGraph",
  "type": "object",
  "required": ["schema_version", "bank_id", "alert_id", "nodes", "edges", "generated_at", "evidence_hash"],
  "properties": {
    "schema_version": { "type": "string" },
    "bank_id": { "type": "string" },
    "alert_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "evidence_hash": { "type": "string" },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "reason"],
        "properties": {
          "field": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "data"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "ALERT",
              "RULE_CONDITION",
              "TRANSACTION",
              "CUSTOMER",
              "AGGREGATE",
              "SANCTIONS_HIT",
              "LAW_CITATION"
            ]
          },
          "data": { "type": "object" },
          "evidence_pointer": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "relation"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "relation": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
